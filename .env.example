DATABASE_URL=postgresql://postgres:postgres@localhost:5433/auth_db
PORT=4000
ADMIN_SECRET=change-me-in-production
ISSUER_URL=http://localhost:4000

# RSA key pair for signing JWTs (RS256)
# Leave blank in development — Sentinel will generate an ephemeral pair on startup
# In production, generate once and paste the PEM values here (newlines as \n)
# See docs/learn/12-persistent-keys.md for generation instructions
PRIVATE_KEY_PEM=
PUBLIC_KEY_PEM=
