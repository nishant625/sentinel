generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id            Int      @id @default(autoincrement())
  clientId      String   @unique
  clientSecret  String?
  name          String
  isPublic      Boolean  @default(true)
  redirectUris  String[]
  scopes        String   @default("openid")
  tokenFormat   String   @default("jwt")   // "jwt" | "opaque"
  createdAt     DateTime @default(now())

  authCodes     AuthCode[]
  tokens        Token[]
  refreshTokens RefreshToken[]
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  authCodes     AuthCode[]
  tokens        Token[]
  refreshTokens RefreshToken[]
}

model AuthCode {
  id                  Int      @id @default(autoincrement())
  code                String   @unique
  userId              Int
  clientId            String
  redirectUri         String
  codeChallenge       String
  codeChallengeMethod String   @default("S256")
  scope               String   @default("openid")
  expiresAt           DateTime
  used                Boolean  @default(false)
  createdAt           DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  client Client @relation(fields: [clientId], references: [clientId])
}

model Token {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  clientId  String
  scope     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  client Client @relation(fields: [clientId], references: [clientId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique   // SHA-256 of the actual token
  userId    Int
  clientId  String
  scope     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  client Client @relation(fields: [clientId], references: [clientId])
}
